# ─────────────────────────────────────────────────────────────
# Mishkitashua — variables de entorno
# Copia este archivo a ".env" y reemplaza con tus llaves reales.
# NUNCA subas ".env" al repositorio (ya está en .gitignore).
# ─────────────────────────────────────────────────────────────

# Base de datos (Neon Postgres)
DATABASE_URL="postgresql://usuario:password@host/db?sslmode=require"

# ── Autenticación: Clerk ──  https://dashboard.clerk.com
# 1) Crea una aplicación (gratis).
# 2) Habilita: OTP por email, MFA (TOTP) y Passkeys (biometría) en "User & Authentication".
# 3) En "Sessions" → "Customize session token" agrega:  { "metadata": "{{user.public_metadata}}" }
#    (necesario para que el rol de admin funcione en el middleware).
# 4) Copia las llaves aquí:
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxx"
CLERK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxx"
# Webhook (para el correo de bienvenida): endpoint /api/webhooks/clerk, evento user.created.
# El nombre lo fija Clerk: verifyWebhook() lee EXACTAMENTE esta variable.
CLERK_WEBHOOK_SIGNING_SECRET="whsec_xxxxxxxxxxxxxxxxxxxx"
# Rutas de auth (no cambiar salvo que muevas las páginas):
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/ingresar"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/registro"

# Para hacerte ADMIN: en el dashboard de Clerk, edita tu usuario →
# "Public metadata" → { "role": "admin" }

# ── Pasarela de pago: Mercado Pago ──  https://www.mercadopago.com.pe/developers/panel
# Pasarela que SÍ opera en Perú: acepta cuenta personal (solo DNI, sin RUC) y
# soporta Yape. Crea una aplicación (producto: Checkout API) y copia sus llaves.
#
# IMPORTANTE: las credenciales de PRUEBA y las de PRODUCCIÓN empiezan AMBAS con
# "APP_USR-"; el prefijo no distingue el entorno. Se toman de secciones distintas
# del panel ("Credenciales de prueba" vs "Credenciales de producción"), y el
# entorno se declara aquí de forma explícita:
MP_TEST_MODE="true"    # "true" con credenciales de prueba; "false" en producción.
MP_ACCESS_TOKEN="APP_USR-xxxxxxxxxxxxxxxxxxxx"
# Webhook de pagos: en el panel de MP, crea una notificación webhook apuntando a
# https://mishkitashua.com/api/webhooks/mercadopago y copia su "clave secreta".
# Con esto el pedido se crea aunque el comprador cierre la pestaña tras pagar.
# OBLIGATORIA en producción: sin ella el webhook rechaza todos los avisos.
MP_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxx"

# ── Correos: Resend ──  https://resend.com
# 1) Añade tu dominio en Resend y copia los registros DKIM/SPF al DNS del
#    proveedor donde lo compraste. Espera a que el estado sea "Verified".
# 2) Sin dominio verificado solo puedes escribir a tu propio correo, y el
#    remitente debe ser "onboarding@resend.dev".
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
EMAIL_FROM="Mishkitashua <pedidos@tudominio.com>"
# El dominio tiene envío pero no recepción: las respuestas de los clientes se
# desvían con Reply-To a una bandeja real. Sin esta variable no se envía Reply-To.
EMAIL_REPLY_TO="tu-correo-real@gmail.com"
# Bandeja donde llegan los mensajes del formulario de contacto. Si no se pone,
# se usa EMAIL_REPLY_TO. Puede ser otra distinta (p. ej. una para consultas).
CONTACT_INBOX=""
# Sin RESEND_API_KEY los correos se registran en consola (MODO SIMULACIÓN).

# Protege el cron de cumpleaños (/api/cron/birthdays). Genera un valor aleatorio.
CRON_SECRET="cambia-esto-por-un-valor-aleatorio"

# ── Imágenes de producto: Vercel Blob ──  https://vercel.com/dashboard/stores
# Crea un store "Blob" (gratis) y Vercel inyecta esta variable en el proyecto.
# Para desarrollo local: Storage → tu Blob store → ".env.local" → copia el token.
# Sin esta variable, subir imágenes en el admin devuelve 503 (el resto funciona).
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx"

# ── Rate limiting ──
# El limitador vive en memoria (app/lib/ratelimit.ts): NO necesita configuración,
# pero tampoco se comparte entre instancias. En serverless cada instancia lleva
# su propio contador, así que el límite real es aproximado. Para uno estricto
# habría que usar un store compartido (Upstash Redis) o el WAF de Vercel.
