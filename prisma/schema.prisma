generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  address   String
  city      String
  orders    Order[]
  reviews   Review[]
  createdAt DateTime @default(now())

  @@index([email])
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customer      Customer    @relation(fields: [customerId], references: [id])
  customerId    String
  items         OrderItem[]
  subtotal        Float
  discount        Float    @default(0)
  giftDescription String?
  shippingCost    Float
  total           Float
  paymentMethod   String
  status        String      @default("confirmado")
  reviews       Review[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model OrderItem {
  id            String  @id @default(cuid())
  order         Order   @relation(fields: [orderId], references: [id])
  orderId       String
  productSlug   String
  productName   String
  quantity      Int
  price         Float
  image         String
  customization String?

  @@index([orderId])
  @@index([productSlug])
}

model Promotion {
  id               String   @id @default(cuid())
  title            String
  description      String?
  type             String
  value            Float?
  productSlug      String?
  minPurchase      Float?
  giftDescription  String?
  startsAt         DateTime
  endsAt           DateTime
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())

  @@index([active, startsAt, endsAt])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  page        String?
  productSlug String?
  sessionId   String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  productSlug String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([orderId, productSlug])
  @@index([productSlug])
  @@index([createdAt])
  @@index([customerId])
}
