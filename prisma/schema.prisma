generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String    @id @default(cuid())
  clerkUserId    String?   @unique
  name           String
  email          String
  phone          String
  address        String
  city           String
  role           String    @default("customer")
  birthdate      DateTime?
  marketingOptIn Boolean   @default(true)
  isDemo         Boolean   @default(false)
  orders         Order[]
  reviews        Review[]
  coupons        Coupon[]
  returns        Return[]
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([birthdate])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  giftDescription String?
  shippingCost    Float
  total           Float
  paymentMethod   String
  // Metadatos de pago NO sensibles (PCI SAQ-A): nunca PAN/CVV.
  // Único: la página de retorno y el webhook de la pasarela intentan crear el
  // mismo pedido casi a la vez. Sin esta restricción, un pago podía acabar en
  // dos pedidos y dos correos; ahora el segundo choca y reutiliza el primero.
  chargeId        String?     @unique
  cardBrand       String?
  cardLast4       String?
  paymentStatus   String      @default("pagado")
  couponCode      String?
  status          String      @default("confirmado")
  // Fechas del ciclo logístico. Sin ellas no se puede calcular OTIF, el tiempo
  // de ciclo ni el nivel de servicio: el estado solo dice dónde está el pedido
  // AHORA, no cuándo llegó ahí.
  promisedAt      DateTime? // fecha comprometida de entrega
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  // Marca los pedidos de ejemplo, para poder distinguirlos de los reales y
  // borrarlos de una vez sin tocar el historial verdadero.
  isDemo          Boolean     @default(false)
  reviews         Review[]
  returns         Return[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
  @@index([isDemo])
}

model OrderItem {
  id            String  @id @default(cuid())
  order         Order   @relation(fields: [orderId], references: [id])
  orderId       String
  productSlug   String
  productName   String
  quantity      Int
  price         Float
  image         String
  customization String?

  @@index([orderId])
  @@index([productSlug])
}

model Promotion {
  id              String   @id @default(cuid())
  title           String
  description     String?
  type            String
  value           Float?
  productSlug     String?
  minPurchase     Float?
  giftDescription String?
  startsAt        DateTime
  endsAt          DateTime
  active          Boolean  @default(true)
  sends           PromotionSend[]
  createdAt       DateTime @default(now())

  @@index([active, startsAt, endsAt])
}

// Registro de a quién se le envió cada correo de marketing. Antes se mandaba y
// no quedaba ni rastro: no se podía saber quién lo recibió, ni cuántas veces,
// ni si el envío fue real o simulado.
//
// Sirve para los dos tipos de envío masivo. Los de cumpleaños no cuelgan de
// ninguna promoción, así que promotionId queda vacío y es `kind` quien
// distingue de qué envío se trata.
model PromotionSend {
  id          String     @id @default(cuid())
  promotion   Promotion? @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  promotionId String?
  kind        String     @default("promocion") // promocion | cumpleanos
  customerId  String
  email       String
  status      String     @default("enviado") // enviado | simulado | fallido
  detail      String? // p. ej. el código del cupón que se le mandó
  createdAt   DateTime   @default(now())

  @@index([promotionId])
  @@index([customerId])
  @@index([kind, createdAt])
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  subtitle        String
  category        String // "alfajores" | "manjares" (validado en la app)
  price           Float
  weight          String
  description     String
  longDescription String
  ingredients     String[]
  allergens       String?
  features        String[]
  image           String
  images          String[]
  color           String
  customizable    Boolean  @default(false)
  flavorOptions   String[]
  boxSize         Int?
  active          Boolean  @default(true) // soft delete / archivar
  // Unidades disponibles. null = no se lleva control: el producto se prepara
  // por encargo ("bajo pedido") y nunca bloquea la compra. Un 0 sí bloquea.
  stock           Int?
  movements       StockMovement[]
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
  @@index([category])
}

// Historial de entradas y salidas de stock. Cada compra web, venta manual o
// ajuste deja una fila: sin esto, el número de stock cambiaría sin que nadie
// pueda saber por qué ni reconstruirlo si algo sale mal.
model StockMovement {
  id        String   @id @default(cuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  delta     Int // negativo = salida, positivo = entrada
  reason    String // venta_web | venta_manual | reposicion | ajuste | devolucion
  note      String?
  orderId   String? // pedido que lo originó, si vino de la tienda
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([createdAt])
}

// Configuración editable del sitio (fila única). Los OrderItem son snapshots,
// así que cambiar esto no afecta pedidos ya hechos.
model SiteSetting {
  id                    String   @id @default("singleton")
  shippingCost          Float    @default(12.0)
  freeShippingThreshold Float? // null = sin umbral de envío gratis
  // Días hábiles comprometidos para la entrega. Define la fecha contra la que
  // se mide el OTIF y el nivel de servicio.
  deliveryDays          Int      @default(3)
  updatedAt             DateTime @updatedAt
}

// Devolución (logística inversa). El cliente la solicita sobre un pedido
// entregado; el admin la aprueba/rechaza y marca reembolsada. El reembolso del
// dinero se hace manualmente en el panel de la pasarela (usando el chargeId del
// pedido); el sistema refleja el estado y avisa al cliente por correo.
model Return {
  id           String    @id @default(cuid())
  order        Order     @relation(fields: [orderId], references: [id])
  // Una devolución por pedido: evita que dos solicitudes simultáneas creen dos
  // filas y que se pueda volver a pedir tras un rechazo.
  orderId      String    @unique
  customer     Customer  @relation(fields: [customerId], references: [id])
  customerId   String
  reason       String
  status       String    @default("solicitada") // solicitada|aprobada|rechazada|reembolsada
  refundAmount Float?
  adminNote    String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  @@index([status])
  @@index([customerId])
}

// Presencia aproximada para el panel de "conectados" (fidelización). Un latido
// (heartbeat) actualiza lastSeen por sesión; si hay sesión Clerk, se estampa el
// cliente. "Conectado" = lastSeen dentro de los últimos minutos.
model Presence {
  sessionId    String   @id
  customerId   String?
  customerName String?
  page         String?
  lastSeen     DateTime @default(now())

  @@index([lastSeen])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  page        String?
  productSlug String?
  sessionId   String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  productSlug String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([orderId, productSlug])
  @@index([productSlug])
  @@index([createdAt])
  @@index([customerId])
  @@index([rating])
}

// Cupón nominal: se emite a UNA persona (p. ej. en su cumpleaños), caduca y
// solo puede canjearse una vez. A diferencia de Promotion, que se aplica sola
// a todo el mundo, este exige que el cliente escriba el código.
model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String // "percent" | "free_shipping"
  value      Float? // porcentaje cuando type = "percent"
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  reason     String    @default("cumpleanos")
  expiresAt  DateTime
  usedAt     DateTime?
  orderId    String?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@index([expiresAt])
}
