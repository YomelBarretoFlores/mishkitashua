generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id             String    @id @default(cuid())
  clerkUserId    String?   @unique
  name           String
  email          String
  phone          String
  address        String
  city           String
  role           String    @default("customer")
  birthdate      DateTime?
  marketingOptIn Boolean   @default(true)
  orders         Order[]
  reviews        Review[]
  coupons        Coupon[]
  returns        Return[]
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([birthdate])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customer        Customer    @relation(fields: [customerId], references: [id])
  customerId      String
  items           OrderItem[]
  subtotal        Float
  discount        Float       @default(0)
  giftDescription String?
  shippingCost    Float
  total           Float
  paymentMethod   String
  // Metadatos de pago NO sensibles (PCI SAQ-A): nunca PAN/CVV.
  // Único: la página de retorno y el webhook de la pasarela intentan crear el
  // mismo pedido casi a la vez. Sin esta restricción, un pago podía acabar en
  // dos pedidos y dos correos; ahora el segundo choca y reutiliza el primero.
  chargeId        String?     @unique
  cardBrand       String?
  cardLast4       String?
  paymentStatus   String      @default("pagado")
  couponCode      String?
  status          String      @default("confirmado")
  reviews         Review[]
  returns         Return[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([customerId])
}

model OrderItem {
  id            String  @id @default(cuid())
  order         Order   @relation(fields: [orderId], references: [id])
  orderId       String
  productSlug   String
  productName   String
  quantity      Int
  price         Float
  image         String
  customization String?

  @@index([orderId])
  @@index([productSlug])
}

model Promotion {
  id              String   @id @default(cuid())
  title           String
  description     String?
  type            String
  value           Float?
  productSlug     String?
  minPurchase     Float?
  giftDescription String?
  startsAt        DateTime
  endsAt          DateTime
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  @@index([active, startsAt, endsAt])
}

model Product {
  id              String   @id @default(cuid())
  slug            String   @unique
  name            String
  subtitle        String
  category        String // "alfajores" | "manjares" (validado en la app)
  price           Float
  weight          String
  description     String
  longDescription String
  ingredients     String[]
  allergens       String?
  features        String[]
  image           String
  images          String[]
  color           String
  customizable    Boolean  @default(false)
  flavorOptions   String[]
  boxSize         Int?
  active          Boolean  @default(true) // soft delete / archivar
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([active])
  @@index([category])
}

// Configuración editable del sitio (fila única). Los OrderItem son snapshots,
// así que cambiar esto no afecta pedidos ya hechos.
model SiteSetting {
  id                    String   @id @default("singleton")
  shippingCost          Float    @default(12.0)
  freeShippingThreshold Float? // null = sin umbral de envío gratis
  updatedAt             DateTime @updatedAt
}

// Devolución (logística inversa). El cliente la solicita sobre un pedido
// entregado; el admin la aprueba/rechaza y marca reembolsada. El reembolso del
// dinero se hace manualmente en el panel de la pasarela (usando el chargeId del
// pedido); el sistema refleja el estado y avisa al cliente por correo.
model Return {
  id           String    @id @default(cuid())
  order        Order     @relation(fields: [orderId], references: [id])
  // Una devolución por pedido: evita que dos solicitudes simultáneas creen dos
  // filas y que se pueda volver a pedir tras un rechazo.
  orderId      String    @unique
  customer     Customer  @relation(fields: [customerId], references: [id])
  customerId   String
  reason       String
  status       String    @default("solicitada") // solicitada|aprobada|rechazada|reembolsada
  refundAmount Float?
  adminNote    String?
  createdAt    DateTime  @default(now())
  resolvedAt   DateTime?

  @@index([status])
  @@index([customerId])
}

// Presencia aproximada para el panel de "conectados" (fidelización). Un latido
// (heartbeat) actualiza lastSeen por sesión; si hay sesión Clerk, se estampa el
// cliente. "Conectado" = lastSeen dentro de los últimos minutos.
model Presence {
  sessionId    String   @id
  customerId   String?
  customerName String?
  page         String?
  lastSeen     DateTime @default(now())

  @@index([lastSeen])
}

model AnalyticsEvent {
  id          String   @id @default(cuid())
  type        String
  page        String?
  productSlug String?
  sessionId   String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

model Review {
  id          String   @id @default(cuid())
  order       Order    @relation(fields: [orderId], references: [id])
  orderId     String
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  productSlug String?
  rating      Int
  comment     String?
  createdAt   DateTime @default(now())

  @@unique([orderId, productSlug])
  @@index([productSlug])
  @@index([createdAt])
  @@index([customerId])
  @@index([rating])
}

// Cupón nominal: se emite a UNA persona (p. ej. en su cumpleaños), caduca y
// solo puede canjearse una vez. A diferencia de Promotion, que se aplica sola
// a todo el mundo, este exige que el cliente escriba el código.
model Coupon {
  id         String    @id @default(cuid())
  code       String    @unique
  type       String // "percent" | "free_shipping"
  value      Float? // porcentaje cuando type = "percent"
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String
  reason     String    @default("cumpleanos")
  expiresAt  DateTime
  usedAt     DateTime?
  orderId    String?
  createdAt  DateTime  @default(now())

  @@index([customerId])
  @@index([expiresAt])
}
